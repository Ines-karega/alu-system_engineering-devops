#!/usr/bin/env bash
# Configures Nginx with a custom 404 page containing "Ceci n'est pas une page"
# and a redirection for /redirect_me

sudo apt-get update
sudo apt-get -y install nginx
sudo ufw allow 'Nginx HTTP'

# Content for index
echo "Holberton School" | sudo tee /var/www/html/index.html > /dev/null

# Custom 404 page
echo "Ceci n'est pas une page" | sudo tee /var/www/html/404.html > /dev/null

# Nginx configuration update (reset and set approach)
config_file="/etc/nginx/sites-available/default"

# 1. First, remove any previous custom configuration to avoid duplicates
sudo sed -i '/error_page 404/d' "$config_file"
sudo sed -i '/location \/redirect_me/,/}/d' "$config_file"

# 2. Add the configuration back cleanly
# We replace the 'server_name _;' line with original + our new rules
# This is more robust than appending multiple times
new_config="server_name _;\n\n\terror_page 404 /404.html;\n\n\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com;\n\t}"
sudo sed -i "s/server_name _;/$new_config/" "$config_file"

# Check if configuration is valid
sudo nginx -t

# Restart Nginx
sudo service nginx restart