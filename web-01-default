server {
    listen 80;
    listen [::]:80;

    server_name _;
	add_header X-Served-By $hostname;

    root /var/www/html;
    index index.html;

    add_header X-Served-By $hostname always;

    location / {
        try_files $uri $uri/ =404;
    }

    access_log /var/log/nginx/portfolio.access.log;
    error_log  /var/log/nginx/portfolio.error.log;
}
